{
  "name": "github-control-center",
  "displayName": "GitHub Control Center",
  "description": "A control center for a developer's daily GitHub activities: PRs to review, your PRs, notifications, and a full PR page inside VSCode",
  "version": "1.6.2",
  "publisher": "mts88",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#24292f",
    "theme": "dark"
  },
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mts88/github-control-center.git"
  },
  "homepage": "https://github.com/mts88/github-control-center#readme",
  "bugs": {
    "url": "https://github.com/mts88/github-control-center/issues"
  },
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=22"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "github",
    "pull request",
    "code review",
    "notifications"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "githubControlCenter",
          "title": "GitHub Control Center",
          "icon": "images/icon-activity.svg"
        }
      ]
    },
    "views": {
      "githubControlCenter": [
        {
          "id": "githubControlCenter.toReview",
          "name": "To Review",
          "icon": "$(git-pull-request)"
        },
        {
          "id": "githubControlCenter.mine",
          "name": "My PRs",
          "icon": "$(git-pull-request)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "githubControlCenter.toReview",
        "contents": "Sign in to GitHub to see pull requests waiting for your review.\n[Sign in to GitHub](command:githubControlCenter.signIn)",
        "when": "!githubControlCenter.signedIn"
      },
      {
        "view": "githubControlCenter.toReview",
        "contents": "No pull requests waiting for your review. All clear. 🎉",
        "when": "githubControlCenter.signedIn"
      },
      {
        "view": "githubControlCenter.mine",
        "contents": "Sign in to GitHub to see your open pull requests.\n[Sign in to GitHub](command:githubControlCenter.signIn)",
        "when": "!githubControlCenter.signedIn"
      },
      {
        "view": "githubControlCenter.mine",
        "contents": "You have no open pull requests.",
        "when": "githubControlCenter.signedIn"
      }
    ],
    "commands": [
      {
        "command": "githubControlCenter.refresh",
        "title": "Refresh",
        "category": "GitHub Control Center",
        "icon": "$(refresh)"
      },
      {
        "command": "githubControlCenter.signIn",
        "title": "Sign in to GitHub",
        "category": "GitHub Control Center"
      },
      {
        "command": "githubControlCenter.openPr",
        "title": "Open on GitHub",
        "category": "GitHub Control Center",
        "icon": "$(link-external)"
      },
      {
        "command": "githubControlCenter.openPrDetails",
        "title": "Open Pull Request Details",
        "category": "GitHub Control Center"
      },
      {
        "command": "githubControlCenter.openFileDiff",
        "title": "Open File Diff",
        "category": "GitHub Control Center"
      },
      {
        "command": "githubControlCenter.viewFilesAsList",
        "title": "View Files as List",
        "category": "GitHub Control Center",
        "icon": "$(list-flat)"
      },
      {
        "command": "githubControlCenter.viewFilesAsTree",
        "title": "View Files as Tree",
        "category": "GitHub Control Center",
        "icon": "$(list-tree)"
      },
      {
        "command": "githubControlCenter.review.addComment",
        "title": "Add Review Comment",
        "category": "GitHub Control Center"
      },
      {
        "command": "githubControlCenter.review.addFileComment",
        "title": "Comment on File",
        "category": "GitHub Control Center",
        "icon": "$(comment-add)"
      },
      {
        "command": "githubControlCenter.review.submit",
        "title": "Submit Review…",
        "category": "GitHub Control Center"
      },
      {
        "command": "githubControlCenter.review.discard",
        "title": "Discard Pending Review",
        "category": "GitHub Control Center"
      },
      {
        "command": "githubControlCenter.review.addSingleComment",
        "title": "Add Single Comment",
        "category": "GitHub Control Center"
      },
      {
        "command": "githubControlCenter.review.resolveThread",
        "title": "Resolve Conversation",
        "category": "GitHub Control Center"
      },
      {
        "command": "githubControlCenter.review.unresolveThread",
        "title": "Unresolve Conversation",
        "category": "GitHub Control Center"
      },
      {
        "command": "githubControlCenter.openSettings",
        "title": "Settings",
        "category": "GitHub Control Center",
        "icon": "$(gear)"
      },
      {
        "command": "githubControlCenter.copyPrUrl",
        "title": "Copy PR URL",
        "category": "GitHub Control Center"
      },
      {
        "command": "githubControlCenter.copyBranchName",
        "title": "Copy Branch Name",
        "category": "GitHub Control Center"
      },
      {
        "command": "githubControlCenter.muteRepo",
        "title": "Mute Repository",
        "category": "GitHub Control Center"
      },
      {
        "command": "githubControlCenter.checkoutPr",
        "title": "Checkout Branch",
        "category": "GitHub Control Center",
        "icon": "$(git-branch)"
      },
      {
        "command": "githubControlCenter.muteOrg",
        "title": "Mute Organization",
        "category": "GitHub Control Center"
      },
      {
        "command": "githubControlCenter.manageMutedRepos",
        "title": "Manage Muted Repositories",
        "category": "GitHub Control Center"
      },
      {
        "command": "githubControlCenter.clearBriefCache",
        "title": "Clear AI Brief Cache",
        "category": "GitHub Control Center"
      }
    ],
    "configuration": [
      {
        "title": "Badge & Notifications",
        "order": 1,
        "properties": {
          "githubControlCenter.badge.countToReview": {
            "type": "boolean",
            "default": true,
            "order": 1,
            "description": "Include PRs waiting for your review in the activity bar badge count."
          },
          "githubControlCenter.badge.countMine": {
            "type": "boolean",
            "default": false,
            "order": 2,
            "description": "Include your own open PRs in the activity bar badge count."
          },
          "githubControlCenter.badge.countReviewed": {
            "type": "boolean",
            "default": false,
            "order": 3,
            "description": "Include PRs you already reviewed (no active re-request) in the activity bar badge count. Off by default: only PRs actually waiting on you count. Has no effect while toReview.hideReviewed is on (hidden PRs are never counted)."
          },
          "githubControlCenter.notifications.enabled": {
            "type": "boolean",
            "default": true,
            "order": 4,
            "description": "Show VSCode notifications for new review requests and for review outcomes (approved / changes requested) on your own PRs."
          }
        }
      },
      {
        "title": "Filtering",
        "order": 2,
        "properties": {
          "githubControlCenter.mutedRepos": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "order": 1,
            "markdownDescription": "Entries to hide from both lists, the badge, and notifications: `owner/repo` mutes a repository, `owner` (or `owner/*`) mutes a whole organization. Tip: use the **GitHub Control Center: Manage Muted Repositories** command for a searchable picker."
          },
          "githubControlCenter.toReview.hideDrafts": {
            "type": "boolean",
            "default": false,
            "order": 2,
            "description": "Hide draft PRs from the To Review list, the badge, and notifications."
          },
          "githubControlCenter.toReview.hideReviewed": {
            "type": "boolean",
            "default": false,
            "order": 3,
            "description": "Hide open PRs you already reviewed (approved, stale, or changes requested) from the To Review list while they wait for a re-request."
          }
        }
      },
      {
        "title": "Pull Requests",
        "order": 3,
        "properties": {
          "githubControlCenter.updateBranch.defaultMethod": {
            "type": "string",
            "enum": [
              "REBASE",
              "MERGE"
            ],
            "enumDescriptions": [
              "Update with rebase (force-pushes the PR branch)",
              "Update with a merge commit"
            ],
            "default": "REBASE",
            "order": 1,
            "description": "Method preselected for the Update branch action in the PR details panel."
          },
          "githubControlCenter.files.layout": {
            "type": "string",
            "enum": [
              "tree",
              "flat"
            ],
            "enumDescriptions": [
              "Directory hierarchy with compacted single-child folders",
              "Flat file list with the directory shown next to each name"
            ],
            "default": "tree",
            "order": 2,
            "description": "How a pull request's changed files are laid out under its row."
          }
        }
      },
      {
        "title": "AI",
        "order": 4,
        "properties": {
          "githubControlCenter.ai.backend": {
            "type": "string",
            "enum": [
              "claude-code"
            ],
            "enumItemLabels": [
              "Claude Code"
            ],
            "enumDescriptions": [
              "The Claude Code CLI in headless mode, using your existing Claude subscription"
            ],
            "default": "claude-code",
            "order": 1,
            "description": "Which local AI backend powers the AI features (PR brief). More backends may be added over time."
          },
          "githubControlCenter.ai.language": {
            "type": "string",
            "default": "English",
            "order": 2,
            "description": "Language AI-generated content (the PR brief) is written in, regardless of the AI backend in use."
          },
          "githubControlCenter.ai.claude.command": {
            "type": "string",
            "default": "claude",
            "scope": "machine",
            "order": 3,
            "description": "Path to the Claude Code CLI. Used only when the AI backend is Claude Code. Machine-scoped: a workspace cannot override it. AI features stay hidden when the binary is not found."
          },
          "githubControlCenter.ai.claude.model": {
            "type": "string",
            "enum": [
              "sonnet",
              "haiku",
              "opus",
              ""
            ],
            "enumItemLabels": [
              "Sonnet",
              "Haiku",
              "Opus",
              "CLI default"
            ],
            "enumDescriptions": [
              "Fast and balanced — recommended for PR briefs",
              "Fastest and cheapest",
              "Most capable, slower and more expensive",
              "Whatever the Claude CLI is configured to use"
            ],
            "default": "sonnet",
            "order": 4,
            "description": "Model passed to `claude --model`. Used only when the AI backend is Claude Code."
          }
        }
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "githubControlCenter.refresh",
          "when": "view == githubControlCenter.toReview || view == githubControlCenter.mine",
          "group": "navigation@1"
        },
        {
          "command": "githubControlCenter.viewFilesAsTree",
          "when": "(view == githubControlCenter.toReview || view == githubControlCenter.mine) && githubControlCenter.filesLayout == flat",
          "group": "1_manage@1"
        },
        {
          "command": "githubControlCenter.viewFilesAsList",
          "when": "(view == githubControlCenter.toReview || view == githubControlCenter.mine) && githubControlCenter.filesLayout == tree",
          "group": "1_manage@1"
        },
        {
          "command": "githubControlCenter.openSettings",
          "when": "view == githubControlCenter.toReview || view == githubControlCenter.mine",
          "group": "navigation@2"
        },
        {
          "command": "githubControlCenter.manageMutedRepos",
          "when": "view == githubControlCenter.toReview || view == githubControlCenter.mine",
          "group": "1_manage"
        }
      ],
      "commandPalette": [
        {
          "command": "githubControlCenter.openPr",
          "when": "false"
        },
        {
          "command": "githubControlCenter.openPrDetails",
          "when": "false"
        },
        {
          "command": "githubControlCenter.openFileDiff",
          "when": "false"
        },
        {
          "command": "githubControlCenter.review.addComment",
          "when": "false"
        },
        {
          "command": "githubControlCenter.review.addFileComment",
          "when": "resourceScheme == ghcc-pr"
        },
        {
          "command": "githubControlCenter.review.submit",
          "when": "githubControlCenter.hasPendingReview"
        },
        {
          "command": "githubControlCenter.review.discard",
          "when": "githubControlCenter.hasPendingReview"
        },
        {
          "command": "githubControlCenter.review.addSingleComment",
          "when": "false"
        },
        {
          "command": "githubControlCenter.review.resolveThread",
          "when": "false"
        },
        {
          "command": "githubControlCenter.review.unresolveThread",
          "when": "false"
        },
        {
          "command": "githubControlCenter.copyPrUrl",
          "when": "false"
        },
        {
          "command": "githubControlCenter.copyBranchName",
          "when": "false"
        },
        {
          "command": "githubControlCenter.muteRepo",
          "when": "false"
        },
        {
          "command": "githubControlCenter.checkoutPr",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "githubControlCenter.checkoutPr",
          "when": "(view == githubControlCenter.toReview || view == githubControlCenter.mine) && viewItem == pr",
          "group": "inline@1"
        },
        {
          "command": "githubControlCenter.openPr",
          "when": "(view == githubControlCenter.toReview || view == githubControlCenter.mine) && viewItem == pr",
          "group": "inline@2"
        },
        {
          "command": "githubControlCenter.copyPrUrl",
          "when": "(view == githubControlCenter.toReview || view == githubControlCenter.mine) && viewItem == pr",
          "group": "1_copy@1"
        },
        {
          "command": "githubControlCenter.copyBranchName",
          "when": "(view == githubControlCenter.toReview || view == githubControlCenter.mine) && viewItem == pr",
          "group": "1_copy@2"
        },
        {
          "command": "githubControlCenter.muteRepo",
          "when": "(view == githubControlCenter.toReview || view == githubControlCenter.mine) && viewItem == pr",
          "group": "2_manage@1"
        },
        {
          "command": "githubControlCenter.muteOrg",
          "when": "(view == githubControlCenter.toReview || view == githubControlCenter.mine) && viewItem == pr",
          "group": "2_manage@2"
        }
      ],
      "editor/title": [
        {
          "command": "githubControlCenter.review.addFileComment",
          "when": "resourceScheme == ghcc-pr",
          "group": "navigation@1"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "githubControlCenter.review.addComment",
          "when": "commentController == githubControlCenter",
          "group": "inline@1"
        },
        {
          "command": "githubControlCenter.review.addSingleComment",
          "when": "commentController == githubControlCenter && commentThreadIsEmpty",
          "group": "inline@2"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "githubControlCenter.review.resolveThread",
          "when": "commentController == githubControlCenter && commentThread == canResolve",
          "group": "navigation@1"
        },
        {
          "command": "githubControlCenter.review.unresolveThread",
          "when": "commentController == githubControlCenter && commentThread == canUnresolve",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "postinstall": "git config core.hooksPath .githooks || true",
    "vscode:prepublish": "node esbuild.js",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.12.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.21.5",
    "eslint": "^10.6.0",
    "mermaid": "^11.16.0",
    "ovsx": "^1.0.2",
    "semantic-release": "^25.0.5",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "yarn@4.17.0"
}

{
  "branches": ["main"],
  "repositoryUrl": "git@github.com:mts88/github-control-center.git",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/changelog",
    ["@semantic-release/npm", { "npmPublish": false }],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "yarn vsce package --no-dependencies -o github-control-center-${nextRelease.version}.vsix"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["package.json", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [{ "path": "github-control-center-*.vsix" }]
      }
    ],
    [
      "@semantic-release/exec",
      {
        "verifyConditionsCmd": "yarn vsce verify-pat mts88",
        "publishCmd": "yarn vsce publish --no-dependencies --packagePath github-control-center-${nextRelease.version}.vsix"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "verifyConditionsCmd": "yarn ovsx verify-pat mts88",
        "publishCmd": "yarn ovsx publish github-control-center-${nextRelease.version}.vsix"
      }
    ]
  ]
}
